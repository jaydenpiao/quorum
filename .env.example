# =============================================================================
# .env.example — local development environment template
#
# WARNING: This file is safe to commit. It contains NO real secrets.
#          docker-compose.yml loads from `.env`, NOT `.env.example`.
#          Copy this file: cp .env.example .env
#          Then fill in real values in .env. Never commit .env.
# =============================================================================

# QUORUM_API_KEYS (required for all mutating routes)
# Format: agent_id:plaintext_key,agent_id:plaintext_key,...
# Use high-entropy random values for the key portion (e.g. openssl rand -hex 32).
# In production, set this via `fly secrets set QUORUM_API_KEYS=...`
QUORUM_API_KEYS=agent_id:plaintext_key_here

# QUORUM_ALLOW_DEMO (optional)
# Set to "true" to enable the POST /api/v1/demo/incident seeder endpoint.
# Leave unset or set to "false" in production deployments.
QUORUM_ALLOW_DEMO=true
