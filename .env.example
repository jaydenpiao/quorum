# =============================================================================
# .env.example — local development environment template
#
# WARNING: This file is safe to commit. It contains NO real secrets.
#          docker-compose.yml loads from `.env`, NOT `.env.example`.
#          Copy this file: cp .env.example .env
#          Then fill in real values in .env. Never commit .env.
# =============================================================================

# QUORUM_API_KEYS (required for all mutating routes)
# Format: agent_id:plaintext_key,agent_id:plaintext_key,...
# Use high-entropy random values for the key portion (e.g. openssl rand -hex 32).
# In production, set this via `fly secrets set QUORUM_API_KEYS=...`
QUORUM_API_KEYS=agent_id:plaintext_key_here

# QUORUM_ALLOW_DEMO (optional)
# Set to "true" to enable the POST /api/v1/demo/incident seeder endpoint.
# Leave unset or set to "false" in production deployments.
QUORUM_ALLOW_DEMO=true

# DATABASE_URL (optional, Phase 3 capstone)
# When set, the service will (in a future PR) project events into Postgres.
# Leave unset to keep the NoOpProjector default — the JSONL log is always
# canonical; Postgres is a derived read-model.
# Local compose default: postgresql+asyncpg://quorum:quorum@postgres:5432/quorum
# DATABASE_URL=

# QUORUM_LOG_LEVEL (optional)
# Overrides the structlog level. Default is INFO.
# QUORUM_LOG_LEVEL=DEBUG

# OTEL_EXPORTER_OTLP_ENDPOINT (optional)
# When set, enables OpenTelemetry trace export via OTLP/HTTP.
# Example: http://otel-collector:4318/v1/traces
# OTEL_EXPORTER_OTLP_ENDPOINT=

# OTEL_SERVICE_NAME (optional)
# Defaults to "quorum". Shown in traces to identify this deployment.
# OTEL_SERVICE_NAME=quorum

# QUORUM_GITHUB_APP_PRIVATE_KEY_B64 (optional, Phase 4 GitHub actuator)
# Base64-encoded PEM contents of the GitHub App's private key. Preferred
# for Fly because it is single-line.
# In production, set via `fly secrets set QUORUM_GITHUB_APP_PRIVATE_KEY_B64=...`.
# QUORUM_GITHUB_APP_PRIVATE_KEY_B64=

# QUORUM_GITHUB_APP_PRIVATE_KEY (optional, Phase 4 GitHub actuator)
# Raw PEM contents of the GitHub App's private key. Set exactly ONE of
# this variable, QUORUM_GITHUB_APP_PRIVATE_KEY_B64, or
# QUORUM_GITHUB_APP_PRIVATE_KEY_PATH.
# QUORUM_GITHUB_APP_PRIVATE_KEY=

# QUORUM_GITHUB_APP_PRIVATE_KEY_PATH (optional, Phase 4 GitHub actuator)
# Filesystem path to the GitHub App's private key PEM. Alternative to
# the env-var forms for deploys that mount secrets as files.
# QUORUM_GITHUB_APP_PRIVATE_KEY_PATH=/run/secrets/github-app.pem

# ANTHROPIC_API_KEY (required only when running the LLM adapter)
# Used by apps/llm_agent (Phase 4 LLM PR 1+) to call the Claude API.
# The API server itself never reads this — only the separate
# `python -m apps.llm_agent.run --agent-id ...` process does.
# In production, set via `fly secrets set ANTHROPIC_API_KEY=...`.
# ANTHROPIC_API_KEY=

# QUORUM_LLM_METRICS_PORT (optional)
# When set, `python -m apps.llm_agent.run` exposes Prometheus metrics
# from the standalone adapter process on this port. Leave unset to
# disable the sidecar metrics server.
# QUORUM_LLM_METRICS_PORT=9107
